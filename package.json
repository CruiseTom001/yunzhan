{
  "name": "yunzhan",
  "private": true,
  "version": "1.0.0",
  "description": "云栈 - 云计算从入门到精通",
  "author": "云栈 <hello@yunzhan.dev>",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "prebuild": "node scripts/check-chapter-counts.cjs",
    "build:fast": "vite build",
    "prebuild:fast": "node scripts/check-chapter-counts.cjs",
    "preview": "vite preview",
    "check": "vue-tsc -b",
    "lint": "eslint . --ext .ts,.vue",
    "lint:fix": "eslint . --ext .ts,.vue --fix",
    "electron:dev": "vite build && electron .",
    "electron:build": "vite build && electron-builder --dir",
    "electron:installer": "vite build && electron-builder --win nsis",
    "electron:start": "electron ."
  },
  "build": {
    "appId": "com.yunzhan.app",
    "productName": "云栈",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "云栈",
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "clsx": "^2.1.1",
    "highlight.js": "^11.9.0",
    "lucide-vue-next": "^0.511.0",
    "markdown-it": "^14.1.0",
    "monaco-editor": "^0.55.1",
    "pinia": "^2.1.7",
    "tailwind-merge": "^3.3.0",
    "vue": "^3.4.15",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@typescript-eslint/eslint-plugin": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "@vitejs/plugin-vue": "^5.0.3",
    "@vue/runtime-dom": "^3.4.15",
    "@vue/tsconfig": "^0.7.0",
    "autoprefixer": "^10.4.17",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.0",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.20.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "~5.5.4",
    "unplugin-vue-dev-locator": "^1.0.0",
    "vite": "^5.4.19",
    "vue-tsc": "^2.2.0"
  }
}
