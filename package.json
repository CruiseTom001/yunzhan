{
  "name": "yunzhan",
  "private": true,
  "version": "1.1.0",
  "description": "云栈 - 云计算从入门到精通",
  "author": "云栈 <hello@yunzhan.dev>",
  "engines": {
    "node": ">=22 <25"
  },
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "prebuild": "node scripts/check-chapter-counts.cjs && node scripts/check-version-sync.cjs",
    "build:fast": "vite build",
    "prebuild:fast": "node scripts/check-chapter-counts.cjs && node scripts/check-version-sync.cjs",
    "preview": "vite preview",
    "server:dev": "node --watch server/index.mjs",
    "server:start": "node server/index.mjs",
    "server:production": "node server/migrate.mjs && node server/index.mjs",
    "server:migrate": "node server/migrate.mjs",
    "server:create-admin": "node server/create-admin.mjs",
    "server:check": "node scripts/check-server-syntax.mjs",
    "vercel:build": "npm run server:migrate && npm run build",
    "check": "vue-tsc -b",
    "policy:check": "node scripts/check-source-policy.mjs",
    "lint": "eslint . --ext .ts,.vue --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.vue --fix",
    "test": "vitest run",
    "quality": "npm run policy:check && npm run check && npm run lint && npm run server:check && npm test && npm run build",
    "icon:windows": "node scripts/generate-windows-icon.mjs",
    "release:check": "npm run quality",
    "release:windows": "npm run release:check && npm run icon:windows && electron-builder --win nsis",
    "electron:dev": "vite build && electron .",
    "electron:build": "vite build && electron-builder --dir",
    "electron:installer": "vite build && electron-builder --win nsis",
    "electron:start": "electron ."
  },
  "build": {
    "appId": "com.yunzhan.app",
    "productName": "云栈",
    "artifactName": "云栈-Setup-${version}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*"
    ],
    "win": {
      "icon": "public/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "云栈",
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dompurify": "^3.4.11",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.3.0",
    "highlight.js": "^11.9.0",
    "lucide-vue-next": "^0.511.0",
    "markdown-it": "^14.3.0",
    "monaco-editor": "^0.55.1",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "pinia": "^2.1.7",
    "tailwind-merge": "^3.3.0",
    "vue": "^3.4.15",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@typescript-eslint/eslint-plugin": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "@vitejs/plugin-vue": "^5.0.3",
    "@vue/runtime-dom": "^3.4.15",
    "@vue/tsconfig": "^0.7.0",
    "autoprefixer": "^10.4.17",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.0",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.20.1",
    "png-to-ico": "^3.0.2",
    "postcss": "^8.4.35",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.1",
    "typescript": "~5.5.4",
    "unplugin-vue-dev-locator": "^1.0.0",
    "vite": "^5.4.19",
    "vitest": "^2.1.9",
    "vue-tsc": "^2.2.0"
  },
  "overrides": {
    "dompurify": "$dompurify"
  }
}
