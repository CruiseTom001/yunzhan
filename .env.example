POSTGRES_PASSWORD=change-me
NODE_ENV=development
DATABASE_URL=postgresql://yunzhan:change-me@127.0.0.1:5432/yunzhan
PORT=8787
APP_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
TRUST_PROXY=false
ALLOW_ELECTRON_FILE_ORIGIN=false
SERVE_STATIC=false
DB_SSL=false
DB_POOL_SIZE=10

# 邮箱注册。密钥只能配置在服务端，不要添加 VITE_ 前缀。
EMAIL_CODE_SECRET=replace-with-a-random-64-character-secret
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=sender@example.com
SMTP_PASSWORD=replace-with-an-email-client-authorization-code
SMTP_FROM=云栈 <sender@example.com>

# 每日学习记录 AI 润色。密钥只配置在服务端环境变量，不要添加 VITE_ 前缀。
AI_PROVIDER_NAME=DeepSeek
AI_BASE_URL=https://api.deepseek.com/v1
AI_API_KEY=replace-with-ai-provider-key
AI_API_FORMAT=chat_completions
AI_MODEL=deepseek-chat

# 仅在执行 npm run server:create-admin 时读取，不要提交真实密码。
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_DISPLAY_NAME=云栈管理员
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-password

# 前端构建时使用。Web 与 API 同域部署时保留 /api。
VITE_API_BASE_URL=/api

# Electron 开发运行可留空；正式安装包需在 electron/api-config.json 配置同一 HTTPS 地址。
YUNZHAN_API_ORIGIN=

# Render 会自动注入该地址；其他平台可留空并通过 APP_ORIGINS 配置正式域名。
RENDER_EXTERNAL_URL=
